{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kore Deck",
  "version": "2.0.0",
  "identifier": "com.koredeck.deck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kore Deck",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Kore Deck"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../streamdeck_v2/pc_agent/": "agent/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "fr-FR"
      }
    }
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:streamdeck.db"]
    }
  }
}
